{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the eVi desktop shell.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  },
  "permissions": [
    "core:default",
    "allow-check-for-update-cmd",
    "allow-open-logs-cmd",
    "allow-open-external-cmd",
    "allow-update-status-cmd"
  ]
}
