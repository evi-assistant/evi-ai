# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Virtual envs
.venv*/
venv/
env/

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Local agent / tooling scratch dirs
.rstk/
# Claude Code local config (settings.local.json, session locks, local rules)
.claude/

# Tauri / Node
desktop/node_modules/
desktop/src-tauri/target/
desktop/src-tauri/gen/
# Tauri build-generated permission schemas (regenerated by tauri-build)
desktop/src-tauri/permissions/autogenerated/
# PyInstaller sidecars staged by build-sidecar
desktop/src-tauri/binaries/

# Local-only secrets
.env
.env.local

# User-level Evi state never belongs in the repo (lives in ~/.evi/)
# but ignore stray test dumps just in case.
.evi/
